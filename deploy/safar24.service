[Unit]
Description=Safar24 Flask Service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/safar24
EnvironmentFile=/var/www/safar24/.env
ExecStart=/var/www/safar24/.venv/bin/gunicorn -c deploy/gunicorn.conf.py wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
